# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Indentation for Python files
[*.py]
indent_style = space
indent_size = 4

# Indentation for JavaScript, JSON, and Web files
[*.{js,jsx,ts,tsx,json,htm,html,css,yml,yaml}]
indent_style = space
indent_size = 2

# Indentation for Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2
